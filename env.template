# Daily Tweet Agent — Environment Variables
# Rename this file to .env and fill in your values

# 1. Free Groq API key → https://console.groq.com → API Keys → Create API Key
GROQ_API_KEY=your_groq_key_here

# 2. Gmail settings (optional — only needed if you want email delivery)
#    EMAIL_PASSWORD must be a Gmail App Password, NOT your login password
#    Get one: myaccount.google.com → Security → App passwords
EMAIL_SENDER=your_gmail@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_RECIPIENT=where_to_send@email.com
